<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="400.0" prefWidth="640.0" spacing="12.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.reminder.TimerControl">
  <padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
  </padding>
  <children>
    <Label text="Screen Break Reminder Settings">
      <font>
        <Font size="30.0"/>
      </font>
    </Label>
    <TextField fx:id="intervalField" maxWidth="Infinity" promptText="Enter the interval at which the reminder will pop up (minutes)."/>
    <Label fx:id="timeLabel" text="0 / 0 minutes"/>
    <ProgressBar fx:id="reminderProgress" maxWidth="Infinity" progress="0.0"/>
    <AnchorPane prefHeight="200.0" prefWidth="200.0">
      <children>
        <CheckBox fx:id="soundAlertCheckBox" mnemonicParsing="false" onAction="#onSoundAlertChanged" text="Enable Sound Alert"/>
        <Label fx:id="soundFileLabel" layoutX="152.0" text="No .mp3/.wav file uploaded"/>
        <Slider fx:id="volumeSlider" layoutX="2.0" layoutY="42.0" prefHeight="14.0" prefWidth="300.0" value="50.0"/>
        <Label layoutX="2.0" layoutY="25.0" text="Sound volume (0 to 100)"/>
      </children>
    </AnchorPane>
    <Region VBox.vgrow="ALWAYS"/>
    <HBox alignment="CENTER_LEFT" spacing="10.0">
      <children>
        <Button fx:id="startButton" mnemonicParsing="false" onAction="#onStart" text="Start the Reminder"/>
        <Button fx:id="stopButton" mnemonicParsing="false" onAction="#onStop" text="Stop the Reminder"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Status:"/>
        <Label fx:id="statusLabel" text="Idle"/>
      </children>
    </HBox>
  </children>
</VBox>
